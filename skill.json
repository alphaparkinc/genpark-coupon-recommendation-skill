{
  "name": "genpark-coupon-recommendation-skill",
  "description": "GenPark dynamic coupon recommendation skill. Compares basket value, category matches, and active coupon codes to recommend the highest discount.",
  "version": "1.0.0",
  "author": "alphaparkinc",
  "inputs": {
    "cart_items": {
      "type": "array",
      "items": {
        "properties": {
          "sku": { "type": "string" },
          "price": { "type": "number" },
          "quantity": { "type": "integer" },
          "category": { "type": "string" }
        },
        "required": ["sku", "price", "quantity", "category"]
      }
    },
    "available_coupons": {
      "type": "array",
      "items": {
        "properties": {
          "code": { "type": "string" },
          "discount_type": { "type": "string", "enum": ["percent", "fixed"] },
          "discount_value": { "type": "number" },
          "min_spend": { "type": "number" },
          "applicable_category": { "type": "string" }
        },
        "required": ["code", "discount_type", "discount_value"]
      }
    }
  },
  "outputs": {
    "recommended_coupon": {
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "savings_amount": { "type": "number" }
      }
    },
    "savings_breakdown": {
      "type": "array",
      "items": {
        "properties": {
          "code": { "type": "string" },
          "eligible": { "type": "boolean" },
          "savings": { "type": "number" },
          "reason": { "type": "string" }
        }
      }
    }
  },
  "prompt": "You are a GenPark coupon analyst agent. Calculate potential discount savings for each coupon in the list, verify minimum spend thresholds and category constraints, and return the optimal coupon code."
}
